---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada — Frame Videos">
  <div class="flex min-h-screen items-center justify-center bg-dark-950 px-4">
    <div class="text-center max-w-md">
      <div class="text-8xl font-bold text-primary-600/20 mb-4">404</div>
      <h1 class="text-3xl font-bold text-white mb-3">Página não encontrada</h1>
      <p class="text-dark-300 mb-8">
        A página que você está procurando não existe ou foi movida.
      </p>
      <a href="/" class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary-700 transition-colors">
        Voltar ao Início
      </a>
    </div>
  </div>
</BaseLayout>
