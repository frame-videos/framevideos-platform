---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Pagamento Cancelado — Frame Videos">
  <div class="flex min-h-screen items-center justify-center bg-dark-950 px-4">
    <div class="text-center max-w-md">
      <!-- Cancel icon -->
      <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-yellow-600/20">
        <svg class="h-10 w-10 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-white mb-3">Pagamento Cancelado</h1>
      <p class="text-dark-300 mb-8">O pagamento foi cancelado. Nenhuma cobrança foi realizada.</p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/dashboard/plan" class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary-700 transition-colors">
          Ver Planos
        </a>
        <a href="/dashboard" class="inline-flex items-center justify-center rounded-lg border border-border px-6 py-2.5 text-sm font-semibold text-dark-200 hover:bg-surface-light transition-colors">
          Voltar ao Dashboard
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
