---
import { PLANS } from '@/lib/constants';
import { cn } from '@/lib/utils';
---

<section id="pricing" class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">
        Planos simples,{' '}
        <span class="text-primary-400">preços honestos</span>
      </h2>
      <p class="mt-4 text-lg text-dark-400 max-w-2xl mx-auto">
        Comece grátis e escale conforme seu negócio cresce. Sem surpresas, sem taxas escondidas.
      </p>
    </div>

    <!-- Plans grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {PLANS.map((plan) => (
        <div
          class={cn(
            'relative rounded-xl border p-6 flex flex-col',
            plan.highlighted
              ? 'border-primary-600 bg-surface shadow-xl shadow-primary-600/10'
              : 'border-border bg-surface',
          )}
        >
          {plan.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-primary-600/20 text-primary-300">
                Mais Popular
              </span>
            </div>
          )}

          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white">{plan.name}</h3>
            <p class="text-sm text-dark-400 mt-1">{plan.description}</p>
          </div>

          <div class="mb-6">
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white">
                {plan.price === 0 ? 'Grátis' : `$${plan.price}`}
              </span>
              {plan.price > 0 && (
                <span class="text-dark-400 text-sm">/{plan.period}</span>
              )}
            </div>
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2">
                <svg
                  class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"
                  />
                </svg>
                <span class="text-sm text-dark-300">{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="/signup"
            class={cn(
              'inline-flex items-center justify-center gap-2 rounded-lg font-semibold transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-dark-950 px-5 py-2.5 text-sm w-full',
              plan.highlighted
                ? 'bg-primary-600 hover:bg-primary-700 text-white shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40'
                : 'border border-primary-600 text-primary-400 hover:bg-primary-600/10',
            )}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
