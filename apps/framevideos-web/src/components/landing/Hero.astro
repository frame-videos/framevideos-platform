---
---

<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-primary-600/15 blur-[120px]"></div>
    <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] rounded-full bg-primary-800/10 blur-[100px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 rounded-full border border-primary-600/30 bg-primary-600/10 px-4 py-1.5 mb-8">
      <span class="h-2 w-2 rounded-full bg-primary-500 animate-pulse"></span>
      <span class="text-sm font-medium text-primary-300">
        Plataforma #1 para sites de vídeos adultos
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight text-white leading-tight">
      Crie seu site de vídeos
      <br />
      <span class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent">
        adultos em minutos
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mx-auto mt-6 max-w-2xl text-lg sm:text-xl text-dark-300 leading-relaxed">
      CMS completo, SEO automático, multi-idioma, analytics e IA integrada.
      Tudo o que você precisa para criar, gerenciar e monetizar seu site de vídeos.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-lg font-semibold transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-dark-950 bg-primary-600 hover:bg-primary-700 text-white shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40 px-8 py-3.5 text-base min-w-[200px]">
        Começar Grátis →
      </a>
      <a href="#features" class="inline-flex items-center justify-center gap-2 rounded-lg font-semibold transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-dark-950 border border-primary-600 text-primary-400 hover:bg-primary-600/10 px-8 py-3.5 text-base min-w-[200px]">
        Ver Recursos
      </a>
    </div>

    <!-- Social proof -->
    <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-8 text-dark-400">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm">Sem cartão de crédito</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm">Setup em 2 minutos</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm">Cancele quando quiser</span>
      </div>
    </div>
  </div>
</section>
