# Frame Videos - Environment Variables

# Backend API URL (Production)
NEXT_PUBLIC_API_URL=https://api.framevideos.com/api/v1

# Alternative: Workers Dev URL (for testing before DNS propagation)
# NEXT_PUBLIC_API_URL=https://frame-videos-prod.frame-videos.workers.dev/api/v1

# Cloudflare R2 Public URL (will be configured after upload implementation)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-frame-videos.r2.dev

# Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Environment
NEXT_PUBLIC_ENV=production
